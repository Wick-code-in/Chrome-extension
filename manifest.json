{
  "manifest_version": 3,
  "name": "Exam Upload Assistant",
  "version": "1.0.0",
  "description": "Guided browser assistant for uploading exam questions to the internal Question Bank.",
  "action": {},
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://aistudio-scrapper.blockverse.tech/*"],
      "js": [
        "lib/parser.js",
        "lib/session.js",
        "lib/domHelpers.js",
        "lib/selectors.js",
        "lib/stateMachine.js",
        "content/loader.js",
        "content/panel.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/panel.css"],
      "matches": ["https://aistudio-scrapper.blockverse.tech/*"]
    }
  ]
}
